# Server-side only. Copy to `.env.local` for local development.

# OpenAI — used for Whisper video/audio scan + recipe structuring
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Instagram Login (Meta App → Instagram API with Instagram Login)
# https://developers.facebook.com/docs/instagram-platform/instagram-api-with-instagram-login
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_REDIRECT_URI=http://localhost:3000/api/auth/instagram/callback

# Optional third-party Instagram media helper (RapidAPI etc.)
# Leave empty to skip. Expected to return JSON with caption / video url fields.
INSTAGRAM_MEDIA_API_URL=
INSTAGRAM_MEDIA_API_KEY=
INSTAGRAM_MEDIA_API_HOST=

# Cookie signing for Instagram session
AUTH_SECRET=change-me-to-a-long-random-string
